# 환경 설정
.env
.env.local
.env.*.local

# 의존성
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# 빌드 결과물
dist/
build/
.next/
out/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# 로그
*.log
logs/

# 테스트 커버리지
coverage/
.nyc_output/
htmlcov/

# 임시 파일
*.tmp
*.temp

# 하네스 파일은 반드시 git에 포함 (팀 공유)
# .claude/ 폴더 절대 gitignore 하지 말 것
# claude-progress.txt 절대 gitignore 하지 말 것
# feature_list.json 절대 gitignore 하지 말 것
# .claude/state/learnings.jsonl — 팀 학습 공유 (커밋 대상)
# .claude/state/checkpoints/ — 세션 인계 체크포인트 (커밋 대상)

# 하네스 세션 로컬 상태 (git에 포함하지 않음)
.claude/state/freeze-dir.txt

# QA Browser 런타임 산출물 (binary + 빈번한 변경 — git 제외)
# .gitkeep 은 포함 대상 (디렉토리 보존)
.claude/state/qa-browser/screenshots/*
!.claude/state/qa-browser/screenshots/.gitkeep
.claude/state/qa-browser/runs/*
!.claude/state/qa-browser/runs/.gitkeep

# Lint 캐시 (세션 로컬 — /project:lint report 재출력용)
.claude/state/lint-last.json

# Backup 캐시 (세션 로컬 — backup.py status 재출력용)
.claude/state/backup-last.json

# 세션 검색 FTS5 색인 (claude.hermes — 로컬 캐시, 언제든 재색인. ADR-010)
.claude/state/sessions.db

# Wiki 런타임 산출물 (wiki.py graph --output 생성 — git 제외)
wiki/graph.md

# Orch 핸드오프 런타임 산출물 (task-id 디렉토리 — gitignore, ADR-008 결정 3)
# .gitkeep + README.md 는 포함 대상 (디렉토리 보존 + 규약 설명)
.claude/state/orch/*/
!.claude/state/orch/.gitkeep
!.claude/state/orch/README.md
